    "applies_to_rendered_glyph_bounds": true
  },
  "occupancy_gate": {
    "hard_source_margin_px": 16,
    "minimum_combined_occupancy": 0.72,
    "preferred_combined_occupancy": 0.82,
    "maximum_combined_occupancy": 0.90,
    "minimum_mascot_height_ratio": {"80": 0.56, "96": 0.60, "100": 0.62},
    "minimum_message_character_height_ratio": 0.64,
    "maximum_message_character_height_ratio": 0.84,
    "message_character_size_is_independent_of_caption_bounds": true,
    "caption_may_overlap_character": false,
    "caption_may_overlap_device": false,
    "evaluate_every_animation_frame": true,
    "minimum_combined_occupancy_evaluation": "union-of-visible-bounds-across-animation",
    "per_frame_evaluation": ["maximum_combined_occupancy", "canvas_margin", "caption_collision", "character_or_device_size"],
    "invisible_caption_lead_in_does_not_fail_minimum_combined_occupancy": true,
    "device_width_may_satisfy_gate": true
  }
