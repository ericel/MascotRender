    "message-512": {
      "width": 512,
      "height": 512,
      "hard_margin": 16,
      "preferred_margin": 24,
      "target_character_height": [0.64, 0.84],
      "vertical_caption_zoom_factor": 0.94,
      "side_caption_zoom_factor": 0.82,
      "minimum_zoom_factor": 0.50,
      "absolute_minimum_zoom": 0.50,
      "zoom_backoff_step": 0.03,
      "zoom_resolution": "largest-renderer-validated-per-sticker-zoom",
      "purpose": "canonical-chat-message-delivery"
    },
    "tray-100": {"width": 100, "height": 100, "target_content_occupancy": 0.86, "target_character_height": [0.62, 0.72]},
    "tray-96": {"width": 96, "height": 96, "target_content_occupancy": 0.85, "target_character_height": [0.60, 0.70]},
    "stress-80": {"width": 80, "height": 80, "target_content_occupancy": 0.82, "target_character_height": [0.56, 0.66]}
  },
  "device_critical_characters": ["H05", "H07", "H12", "H13"],
  "device_critical_policy": {"target_width_occupancy": [0.72, 0.86], "preserve_complete_device": true},
  "caption_readability": {
    "minimum_maximum_visible_height_ratio": 0.10,
