{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mascotrender.dev/schema/character-identity-v1.json",
  "title": "MascotRender character identity contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "characterId", "identity", "validation"],
  "properties": {
    "schema_version": { "const": 1 },
    "characterId": { "type": "string", "minLength": 1 },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primaryColor",
        "secondaryColor",
        "accentColor",
        "outlineColor",
        "headAspectRatio",
        "headToBodyRatio",
        "eyeSpacingRatio",
        "eyeVerticalRatio",
        "mouthVerticalRatio",
        "antennaHeightRatio",
        "requiredFeatures"
      ],
      "properties": {
        "primaryColor": { "$ref": "#/$defs/color" },
        "secondaryColor": { "$ref": "#/$defs/color" },
        "accentColor": { "$ref": "#/$defs/color" },
        "outlineColor": { "$ref": "#/$defs/color" },
        "headAspectRatio": { "$ref": "#/$defs/ratio" },
        "headToBodyRatio": { "$ref": "#/$defs/ratio" },
        "eyeSpacingRatio": { "$ref": "#/$defs/ratio" },
        "eyeVerticalRatio": { "$ref": "#/$defs/ratio" },
        "mouthVerticalRatio": { "$ref": "#/$defs/ratio" },
        "antennaHeightRatio": { "$ref": "#/$defs/ratio" },
        "requiredFeatures": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ratioTolerance", "measurements"],
      "properties": {
        "ratioTolerance": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.25
        },
        "measurements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "headAspectRatio",
            "headToBodyRatio",
            "eyeSpacingRatio",
            "eyeVerticalRatio",
            "mouthVerticalRatio",
            "antennaHeightRatio"
          ],
          "properties": {
            "headAspectRatio": { "$ref": "#/$defs/measurement" },
            "headToBodyRatio": { "$ref": "#/$defs/measurement" },
            "eyeSpacingRatio": { "$ref": "#/$defs/measurement" },
            "eyeVerticalRatio": { "$ref": "#/$defs/measurement" },
            "mouthVerticalRatio": { "$ref": "#/$defs/measurement" },
            "antennaHeightRatio": { "$ref": "#/$defs/measurement" }
          }
        }
      }
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-F]{6}$"
    },
    "ratio": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 10
    },
    "measurement": {
      "type": "string",
      "minLength": 1
    }
  }
}
