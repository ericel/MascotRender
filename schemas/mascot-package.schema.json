{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mascotrender.dev/schema/mascot-package-v1.json",
  "title": "MascotRender portable package manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "package_id", "package_version", "character_id", "status", "engine", "entry_points", "files", "capabilities", "licenses", "provenance"],
  "properties": {
    "format_version": { "const": 1 },
    "package_id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{2,127}$" },
    "package_version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$" },
    "character_id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{2,127}$" },
    "status": { "enum": ["technical-fixture", "review-candidate", "production"] },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_major", "minimum_version"],
      "properties": {
        "api_major": { "type": "integer", "minimum": 0 },
        "minimum_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    },
    "entry_points": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/safePath" },
      "required": ["identity", "rig"]
    },
    "files": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "role"],
        "properties": {
          "path": { "$ref": "#/$defs/safePath" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "role": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{1,63}$" }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backends", "outputs", "framings", "semantics"],
      "properties": {
        "backends": { "$ref": "#/$defs/nonemptyUniqueStrings" },
        "outputs": { "$ref": "#/$defs/nonemptyUniqueStrings" },
        "framings": { "$ref": "#/$defs/nonemptyUniqueStrings" },
        "semantics": { "$ref": "#/$defs/nonemptyUniqueStrings" }
      }
    },
    "default_locale": { "type": "string", "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$" },
    "licenses": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/safePath" } },
    "provenance": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/safePath" } }
  },
  "$defs": {
    "safePath": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[^\\u0000]+$" },
    "nonemptyUniqueStrings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
