{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mascotrender.dev/schema/pack-v1.json",
  "title": "MascotRender pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "canvas",
    "layers",
    "base_layers",
    "expressions",
    "poses",
    "provenance",
    "anchors",
    "pivots"
  ],
  "$defs": {
    "layerIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "rect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number", "minimum": 0 },
        "y": { "type": "number", "minimum": 0 },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "rgb": {
      "type": "object",
      "additionalProperties": false,
      "required": ["r", "g", "b"],
      "properties": {
        "r": { "type": "integer", "minimum": 0, "maximum": 255 },
        "g": { "type": "integer", "minimum": 0, "maximum": 255 },
        "b": { "type": "integer", "minimum": 0, "maximum": 255 }
      }
    }
  },
  "properties": {
    "schema_version": { "const": 1 },
    "pack_id": { "type": "string", "minLength": 1 },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "height": { "type": "integer", "minimum": 1, "maximum": 4096 }
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "z"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "pattern": "^[^:/\\\\]+(?:/[^:/\\\\]+)*\\.svg$" },
          "z": { "type": "integer" }
        }
      }
    },
    "base_layers": { "$ref": "#/$defs/layerIds" },
    "expressions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/layerIds" }
    },
    "poses": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/layerIds" }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["creator", "license", "source"],
      "properties": {
        "creator": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "anchors": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/point" }
    },
    "pivots": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/point" }
    },
    "text_slots": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/rect" }
    },
    "fonts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "license"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "pattern": "^[^:/\\\\]+(?:/[^:/\\\\]+)*\\.ttf$" },
          "license": { "type": "string", "pattern": "^[^:/\\\\]+(?:/[^:/\\\\]+)*\\.txt$" }
        }
      }
    },
    "text_styles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "font",
          "safe_area",
          "min_font_size",
          "max_font_size",
          "max_lines",
          "fill"
        ],
        "properties": {
          "font": { "type": "string", "minLength": 1 },
          "safe_area": { "$ref": "#/$defs/rect" },
          "min_font_size": { "type": "number", "exclusiveMinimum": 0, "maximum": 512 },
          "max_font_size": { "type": "number", "exclusiveMinimum": 0, "maximum": 512 },
          "max_lines": { "type": "integer", "minimum": 1, "maximum": 3 },
          "fill": { "$ref": "#/$defs/rgb" },
          "outline": {
            "type": "object",
            "additionalProperties": false,
            "required": ["width", "color"],
            "properties": {
              "width": { "type": "number", "minimum": 0, "maximum": 32 },
              "color": { "$ref": "#/$defs/rgb" }
            }
          }
        }
      }
    },
    "variation_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "choices"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "choices": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/layerIds" }
          }
        }
      }
    }
  }
}
