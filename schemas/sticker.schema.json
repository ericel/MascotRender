{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mascotrender.dev/schema/sticker-v1.json",
  "title": "MascotRender sticker specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sticker_id",
    "pack_id",
    "expression",
    "pose"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "sticker_id": { "type": "string", "minLength": 1 },
    "pack_id": { "type": "string", "minLength": 1 },
    "alt_text": { "type": "string" },
    "phrase_id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$" },
    "recipe_id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$" },
    "intent": { "type": "string", "minLength": 1 },
    "pose_implementation": { "type": "string", "minLength": 1 },
    "audience_class": { "enum": ["general", "teen-and-up", "adult", "pack-specific"] },
    "accessible_description": { "type": "string", "minLength": 1 },
    "expression": { "type": "string", "minLength": 1 },
    "pose": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer", "minimum": 0 },
    "layers": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number", "minimum": -128, "maximum": 128 },
        "y": { "type": "number", "minimum": -128, "maximum": 128 }
      }
    },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framing", "target", "zoom"],
      "properties": {
        "framing": {
          "enum": ["face-closeup", "bust", "three-quarter", "full-body", "dynamic-full-body"]
        },
        "target": { "type": "string", "minLength": 1 },
        "zoom": { "type": "number", "minimum": 0.5, "maximum": 3.0 },
        "offset_x": { "type": "number", "minimum": -512, "maximum": 512 },
        "offset_y": { "type": "number", "minimum": -512, "maximum": 512 }
      }
    },
    "text": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "style"],
      "properties": {
        "content": { "type": "string", "minLength": 1, "maxLength": 280 },
        "style": { "type": "string", "minLength": 1 },
        "placement": { "type": "string", "minLength": 1 },
        "preferred_slots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "animation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duration_ms", "fps", "loop"],
      "anyOf": [
        { "required": ["overlays"] },
        { "required": ["tracks"] }
      ],
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 100, "maximum": 10000 },
        "fps": { "type": "integer", "minimum": 1, "maximum": 30 },
        "loop": {
          "enum": ["once", "loop", "ping_pong", "hold_last_frame"]
        },
        "overlays": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "body_bounce",
              "text_pop",
              "text_pulse",
              "text_wobble",
              "text_float"
            ]
          }
        },
        "tracks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target", "property", "keyframes"],
            "properties": {
              "target": { "type": "string", "minLength": 1 },
              "property": {
                "enum": [
                  "translate_x",
                  "translate_y",
                  "scale_x",
                  "scale_y",
                  "rotation_degrees",
                  "opacity",
                  "view_x",
                  "view_y"
                ]
              },
              "keyframes": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["at_ms", "value"],
                  "properties": {
                    "at_ms": { "type": "integer", "minimum": 0 },
                    "value": { "type": "number" },
                    "easing": {
                      "enum": [
                        "linear",
                        "ease_out",
                        "ease_in_out",
                        "back_out"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
